# Parallel Cafe — Environment Variables
# Copy this file to .env.local and fill in real values before production.

# Sanity CMS
# Replace "placeholder-project-id" with your real Sanity project ID from https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID="placeholder-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Sanity write token (server-side only — NEVER expose in client code)
# Only needed if you enable server-side mutations (e.g., form submissions to Sanity)
# SANITY_API_WRITE_TOKEN="your-write-token-here"

# Contact form (future)
# CONTACT_EMAIL_API_KEY="your-email-service-key"
# UPSTASH_REDIS_REST_URL="your-upstash-url"
# UPSTASH_REDIS_REST_TOKEN="your-upstash-token"
